# write the code..
l = []
def menu():
	print("1. Add")
	print("2. Remove")
	print("3. Display")
	print("4. Quit")

def add():
	
	I = int(input("Integer: "))
	l.append(I)
	print(f"List after adding: {l}")

def Remove():
	if len(l)>0:
		U = int(input("Integer: "))
		if U in l:
			l.remove(U)
			print(f"List after removing: {l}")
		else:
			print("Element not found")
	else:
		print("List is empty")

def Display():
	if len(l)>0:
		print(l)
	else:
		print("List is empty")



while True:
	menu()
	K = int(input("Enter choice: "))
	if K==1:
		add()
	elif K==2:
		Remove()
	elif K==3:
		Display()
	elif K==4:
		break
	else:
		print("Invalid choice")
		