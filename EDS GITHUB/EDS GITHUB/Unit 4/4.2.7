import pandas as pd
import numpy as np

# Load the Titanic dataset
data = pd.read_csv('Titanic-Dataset.csv')
data['FamilySize'] = data['SibSp'] + data['Parch']
data['IsAlone'] = np.where(data['FamilySize'] > 0, 0, 1)
data = pd.get_dummies(data, columns=['Embarked'], drop_first=True)

# 1. Calculate the survival rate by class
survival_rate_by_class = data.groupby('Pclass')['Survived'].mean()
survival_rate_by_embarked_s = data.groupby('Embarked_S')['Survived'].mean()
survival_rate_by_family_size = data.groupby('FamilySize')['Survived'].mean()
survival_rate_by_is_alone = data.groupby('IsAlone')['Survived'].mean()
avg_fare_by_class = data.groupby('Pclass')['Fare'].mean()
avg_age_by_class = data.groupby('Pclass')['Age'].mean()
avg_age_by_survived = data.groupby('Survived')['Age'].mean()
avg_fare_by_survived = data.groupby('Survived')['Fare'].mean()

# 2. Calculate the survival rate by embarked location
survivors_count = data[data['Survived'] == 1]['Pclass'].value_counts()
# Reorder to 1,3,2 as per your output
survivors_count = survivors_count.reindex([1,3,2])

# Count non-survivors by class
non_survivors_count = data[data['Survived'] == 0]['Pclass'].value_counts()
# Reorder to 3,2,1 as per your output
non_survivors_count = non_survivors_count.reindex([3,2,1])

# 3. Calculate the survival rate by family size
print(survival_rate_by_class)
print(survival_rate_by_embarked_s)
print(survival_rate_by_family_size)


# 4. Calculate the survival rate by being alone
print(survival_rate_by_is_alone)

# 5. Get the average fare by class
print(avg_fare_by_class)

# 6. Get the average age by class
print(avg_age_by_class)

# 7. Get the average age by survival status
print(avg_age_by_survived)
# 8. Get the average fare by survival status
print(avg_fare_by_survived)

# 9. Get the number of survivors by class
print(survivors_count)

# 10. Get the number of non-survivors by class
print(non_survivors_count)